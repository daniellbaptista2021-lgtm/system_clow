{
  "app": {
    "name": "Sistema de Vendas",
    "version": "2.1.0",
    "environment": "production",
    "debug": false
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "vendas_db",
    "username": "admin",
    "password": "senha_segura_123",
    "ssl": true,
    "pool": {
      "min": 2,
      "max": 10,
      "timeout": 30000
    }
  },
  "api": {
    "baseUrl": "https://api.vendas.com.br",
    "version": "v1",
    "timeout": 15000,
    "rateLimit": {
      "requests": 1000,
      "window": 3600
    }
  },
  "auth": {
    "jwtSecret": "minha_chave_jwt_super_secreta",
    "tokenExpiry": "24h",
    "refreshTokenExpiry": "7d",
    "bcryptRounds": 12
  },
  "email": {
    "provider": "smtp",
    "host": "smtp.gmail.com",
    "port": 587,
    "secure": false,
    "auth": {
      "user": "sistema@vendas.com.br",
      "pass": "senha_email_app"
    }
  },
  "storage": {
    "type": "s3",
    "bucket": "vendas-arquivos",
    "region": "us-east-1",
    "maxFileSize": "10MB",
    "allowedTypes": ["jpg", "png", "pdf", "xlsx", "csv"]
  },
  "features": {
    "relatorios": true,
    "notificacoes": true,
    "backup_automatico": true,
    "analytics": true,
    "multi_tenant": false
  },
  "logging": {
    "level": "info",
    "file": "/var/log/vendas.log",
    "maxSize": "100MB",
    "maxFiles": 5,
    "format": "json"
  },
  "cache": {
    "type": "redis",
    "host": "localhost",
    "port": 6379,
    "ttl": 3600,
    "prefix": "vendas:"
  },
  "monitoring": {
    "enabled": true,
    "endpoint": "https://monitoring.vendas.com.br/metrics",
    "interval": 60,
    "alerts": {
      "email": ["admin@vendas.com.br"],
      "slack": "#alerts"
    }
  }
}