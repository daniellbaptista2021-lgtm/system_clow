{
  "name": "system-clow",
  "version": "1.0.0",
  "description": "System Clow - AI-powered coding agent powered by Anthropic Claude Sonnet 4.6",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "clow": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "server": "node dist/server/server.js",
    "dev": "tsx src/cli.ts",
    "dev:server": "tsx src/server/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "chalk": "^5.4.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.0",
    "exceljs": "^4.4.0",
    "glob": "^11.0.0",
    "hono": "^4.12.12",
    "json-schema-to-zod": "^2.8.1",
    "json-stable-stringify": "^1.3.0",
    "lodash-es": "^4.17.21",
    "marked": "^15.0.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "picomatch": "^4.0.0",
    "proper-lockfile": "^4.1.2",
    "readline": "^1.3.0",
    "strip-ansi": "^7.1.0",
    "tree-kill": "^1.2.2",
    "turndown": "^7.2.4",
    "uuid": "^11.1.0",
    "better-sqlite3": "^11.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/json-stable-stringify": "^1.1.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.15.0",
    "@types/picomatch": "^3.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "sharp": "^0.34.5",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "@vitest/coverage-v8": "^3.1.0"
  }
}
