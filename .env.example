# ═══════════════════════════════════════════════════════════════════════
# System Clow — Configuration template
# Copie este arquivo para .env (chmod 600) e preencha apenas os valores reais.
# NUNCA commite o .env.
# ═══════════════════════════════════════════════════════════════════════

# ─── Gateway IA (LiteLLM proxy local → OpenRouter → GLM-5.1) ───────────
# O SDK Anthropic é usado, mas todo tráfego é redirecionado para o LiteLLM
# em 127.0.0.1:4000, que mapeia qualquer alias claude-* para z-ai/glm-5.1.
ANTHROPIC_API_KEY=sk-clow-proxy-local
ANTHROPIC_BASE_URL=http://127.0.0.1:4000
LITELLM_PROXY_URL=http://127.0.0.1:4000
CLOW_MODEL=glm-5.1
OPENROUTER_API_KEY=                 # obrigatória — https://openrouter.ai/keys

# ─── OpenAI (apenas Whisper + visão, NÃO chat) ─────────────────────────
# Usada só para:
#  - transcrição de áudios recebidos no WhatsApp (Whisper)
#  - OCR de PDF/imagem (GPT-4o-mini)
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o-mini

# ─── Servidor ──────────────────────────────────────────────────────────
PORT=3001
CLOW_PUBLIC_BASE_URL=https://seu-dominio.com.br
CLOW_USE_HTTPS=false                # nginx faz TLS na frente
CLOW_ALLOWED_ORIGINS=https://seu-dominio.com.br

# ─── Auth admin ────────────────────────────────────────────────────────
CLOW_ADMIN_USER=
CLOW_ADMIN_PASS=
CLOW_ADMIN_KEY=
CLOW_ADMIN_SESSION_SECRET=          # gerar com: openssl rand -hex 32
CLOW_USER_SESSION_SECRET=           # gerar com: openssl rand -hex 32
CLOW_CRM_SECRET=                    # AES-256 pra credenciais (32 bytes hex)
CLOW_ADMIN_BASH_PASSWORD=           # destrava Bash em sessões admin
JWT_SECRET=                         # opcional, fallback de signing

# ─── Integração com Clow main (iframe parent) ──────────────────────────
CLOW_BACKEND_URL=https://app-pai.com.br
CLOW_SONNET_SECRET=
CLOW_IFRAME_PARENT=https://app-pai.com.br

# ─── WhatsApp Meta Cloud API ───────────────────────────────────────────
META_WA_ACCESS_TOKEN=               # System User token
META_WA_PHONE_NUMBER_ID=
META_WA_BUSINESS_ACCOUNT_ID=
META_WA_APP_ID=
META_WA_PAGE_ID=
META_WA_VERIFY_TOKEN=               # token aleatório pra validar webhook
META_WA_ADMIN_PHONES=               # E.164, separado por vírgula (ex: 5511999998888)
META_WA_API_VERSION=v22.0

# ─── Z-API (opcional, multi-canal por tenant) ──────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_SECURITY_TOKEN=

# ─── Stripe (billing) ──────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=               # plano Starter R$ 347/mês
STRIPE_PRICE_PROFISSIONAL=          # plano Profissional R$ 697/mês
STRIPE_PRICE_EMPRESARIAL=           # plano Empresarial R$ 1.297/mês
STRIPE_PRICE_WHATSAPP_ADDON=        # add-on Z-API R$ 100/nº/mês
STRIPE_SUCCESS_URL=https://seu-dominio.com.br/signup/success
STRIPE_CANCEL_URL=https://seu-dominio.com.br/signup

# ─── Web Push (PWA) ────────────────────────────────────────────────────
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@seu-dominio.com.br

# ─── Outros (opcionais) ────────────────────────────────────────────────
GOOGLE_API_KEY=                     # Google Speech-to-Text (fallback de Whisper)
BRAVE_SEARCH_API_KEY=               # tool WebSearch
CLOW_DOWNLOADS_DIR=                 # roots de download (path delim do OS)
