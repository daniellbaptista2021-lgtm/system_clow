# System Clow - Configuration
# Copy this to .env and fill in your values

# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude model
CLOW_MODEL=claude-sonnet-4-6

# Web admin login
CLOW_ADMIN_USER=admin
CLOW_ADMIN_PASS=change-me
CLOW_ADMIN_KEY=change-me-too
CLOW_ADMIN_SESSION_SECRET=change-me-session-secret

# Anthropic Claude API Key (optional)
ANTHROPIC_API_KEY=

# Model override
CLOW_MODEL=claude-sonnet-4-6

# Server port (default 3001)
PORT=3001

# Admin key for /admin endpoints and admin session signing
CLOW_ADMIN_KEY=your-admin-key-here

# Admin web login credentials
CLOW_ADMIN_USER=
CLOW_ADMIN_PASS=

# Optional dedicated signing secret for admin sessions
JWT_SECRET=

# Optional comma-separated CORS allowlist for cross-origin clients
# Example: https://app.example.com,https://admin.example.com
CLOW_ALLOWED_ORIGINS=

# Optional download roots separated by the OS path delimiter
# Windows example: C:\\clow\\output;C:\\clow\\tmp
# Linux/macOS example: /srv/clow/output:/srv/clow/tmp
CLOW_DOWNLOADS_DIR=

# Brave Search API key for WebSearch tool (optional)
BRAVE_SEARCH_API_KEY=

# Z-API WhatsApp integration (optional)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_SECURITY_TOKEN=
