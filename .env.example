# System Clow - Configuration
# Copy this to .env and fill in your values

# DeepSeek API Key (required)
DEEPSEEK_API_KEY=sk-your-key-here

# Server port (default 3001)
PORT=3001

# Admin key for /admin endpoints (optional)
CLOW_ADMIN_KEY=your-admin-key-here

# Brave Search API key for WebSearch tool (optional)
BRAVE_SEARCH_API_KEY=

# Z-API WhatsApp integration (optional)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_SECURITY_TOKEN=
